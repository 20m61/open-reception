{
  "name": "open-reception",
  "version": "0.1.0",
  "private": true,
  "description": "iPad 受付端末向け無人受付システム",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:open-next": "open-next build",
    "seed:dynamodb": "tsx scripts/seed-dynamodb.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "lighthouse": "lhci autorun",
    "audit:deps": "npm audit --omit=dev",
    "sast": "semgrep scan --config p/default --error",
    "secrets:scan": "gitleaks detect --no-banner --redact"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@pixiv/three-vrm": "^3.5.4",
    "@pixiv/three-vrm-animation": "3.5.4",
    "jsqr": "^1.4.0",
    "next": "16.2.9",
    "qrcode-generator": "^2.0.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@aws-sdk/client-polly": "3.1075.0",
    "@aws-sdk/client-ssm": "3.1075.0",
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@opennextjs/aws": "4.0.3",
    "@playwright/test": "1.61.1",
    "@types/aws-lambda": "8.10.162",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "tmp": ">=0.2.5"
  }
}
