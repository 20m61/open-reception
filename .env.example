# open-reception 環境変数サンプル (issue #6 で方針を拡充)
# 秘匿値は server-only でのみ参照し、NEXT_PUBLIC_ を付けない。

# Vonage 資格情報（撤去済み・テナント設定へ移行 / issue #405 Inc3, docs/tenant-provider-secrets.md）
# 通話/通知の資格情報供給は **グローバル env を読まなくなった**。供給源はテナント別設定
# （非秘密設定 = TenantProviderConfig / secret = Secrets Manager の tenants/<tenantId>/vonage）で、
# 実行時は resolveProviderForTenant(tenantId) が解決する（未設定テナントは Mock）。
# 旧 env（VONAGE_ENABLED / VONAGE_APPLICATION_ID / VONAGE_PRIVATE_KEY / VONAGE_API_KEY /
# VONAGE_API_SECRET / VONAGE_NOTIFY_* / VONAGE_SECRET_ARN）はここでは設定しない。
#   移行手順は docs/tenant-provider-secrets.md「旧 VONAGE_* env からの移行」を参照。
# 注: /platform/integrations の presence 表示（#90/#93）が旧 env 名を暫定で読む後方互換が残るが、
#     資格情報の供給には使われない（表示のテナント設定 presence への移行は別増分）。
# 担当者応答リンクの署名鍵（Vonage 資格情報ではない。未設定時は KIOSK_SESSION_SECRET にフォールバック）
CALL_ANSWER_SECRET=
# 受付端末が読み込む Vonage(OpenTok 互換) client SDK の URL（公開値。既定は OpenTok.js CDN）
# NEXT_PUBLIC_VONAGE_SDK_URL=https://static.opentok.com/v2/js/opentok.min.js

# テナント別 CCaaS プロバイダ secret のバックエンド (issue #405 Inc2, docs/tenant-provider-secrets.md)
#   memory（既定・未指定時も。dev/test/CI: プロセス内 mock。現行動作不変）
#   secrets-manager（本番: AWS Secrets Manager。参照名 tenants/<tenantId>/<provider> を
#                    <PROVIDER_SECRET_PREFIX>/tenants/<tenantId>/<provider> へ写像）
# AWS デプロイ時は WebStack が secrets-manager 選択時に PROVIDER_SECRET_BACKEND/PREFIX を自動注入する。
# secret 値そのものはここに置かない（write-only。設定 API 経由で Secrets Manager に作成される）。
PROVIDER_SECRET_BACKEND=memory
# PROVIDER_SECRET_PREFIX=open-reception/prod   # secrets-manager のとき必須（環境 prefix。fail-closed）

# 管理画面認証用 secret / パスワード (server-only)
# ADMIN_SESSION_SECRET は HMAC 署名鍵。32 バイト以上推奨（例: openssl rand -hex 32）。
ADMIN_SESSION_SECRET=
ADMIN_PASSWORD=

# kiosk session 署名用 secret / 受付端末許可 PIN (server-only)
KIOSK_SESSION_SECRET=
KIOSK_PIN=
# 受付URL/QR エンロールトークンの署名鍵 (server-only, docs/reception-issuance-design.md)。
# 未認証の /api/kiosk/enroll の信頼根。実デプロイ(Lambda)で未設定だと fail-closed で発行/
# エンロールが 500 になる。32 バイト以上推奨（例: openssl rand -hex 32）。
KIOSK_ENROLLMENT_SECRET=

# 受付アバターの既定 VRM モデル URL (issue #31)。管理画面で VRM 未登録/未選択のとき使う。
# 例: public/avatar/ にライセンス確認済みの .vrm を置き `/avatar/default.vrm` を指す。
# 空 / none / off で VRM 無し（プレースホルダ表示）。詳細は public/avatar/README.md。
KIOSK_DEFAULT_VRM_URL=

# 管理画面 認証プロバイダ切替 (オプション, issue #70)
#   none（既定・パスワード） | entra（Microsoft Entra ID / SSO） | cognito（未実装）
ADMIN_AUTH_PROVIDER=none
# SSO 利用時に認証を一時緩和するフラグ。本番（NODE_ENV=production）では false 不可。
# ADMIN_AUTH_REQUIRED=true
# --- ADMIN_AUTH_PROVIDER=entra のとき使用 ---
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_ISSUER=https://login.microsoftonline.com/<tenantId>/v2.0
# ENTRA_AUDIENCE=
# ENTRA_SCOPE=openid profile email
# ADMIN_ALLOWED_ROLES=OpenReception.Admin,OpenReception.SiteManager,OpenReception.Viewer

# 永続化バックエンド (docs/persistence-design.md)
#   memory（既定・dev/test/CI: プロセス内） | dynamodb（本番: AWS シングルテーブル）
# AWS デプロイ時は WebStack が DATA_BACKEND=dynamodb と TABLE_NAME を自動設定する。
# ローカルから DynamoDB を使う/seed する場合のみ手動で指定する。
DATA_BACKEND=memory
# TABLE_NAME=                       # DATA_BACKEND=dynamodb のとき必須（WebStack の DataTableName 出力）
# RECEPTION_SESSION_TTL_SEC=86400   # 受付セッションの TTL 秒（既定 24h）

# AWS デプロイ時、server Lambda には NODE_ENV=production が CDK(WebStack) から自動設定される。
# 上記のうち本番で必要な値は Secrets Manager / SSM / デプロイ時 context で注入する
# （平文コミットしない）。詳細は docs/deploy-aws.md。
